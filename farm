    local function AddDropdown(section, title, desc, values, default, callback)
        return section:Dropdown(title, desc, values, function(option)
            _G[default] = option
            if callback then callback(option) end
        end, _G[default])
    end

    -- ฟังก์ชันเพิ่ม Slider
    local function AddSlider(section, title, desc, min, max, value, callback)

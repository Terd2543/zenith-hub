-- ========== ระบบ Bypass กันแบน (ปรับปรุงให้เข้ากับสคริปต์หลัก) ==========
local bypassLoaded = false
local function setupBypass()
    if bypassLoaded then return end
    bypassLoaded = true

    -- รอให้โมดูลหลักโหลด
    local success, Modules = pcall(function()
        return ReplicatedStorage:WaitForChild("Modules", 5)
    end)
    if not success then
        warn("Bypass: ไม่พบ Modules ใน ReplicatedStorage")
        return
    end

    -- ปิดเสียงเตือน "IS ALREADY BEING LISTENED TO"
    local function silenceListenWarnings()
        local character = LocalPlayer.Character
        if character then
            local humanoid = character:FindFirstChildOfClass("Humanoid")
            if humanoid and not humanoid:FindFirstChild("silence_listen_warning") then
                local silence = Instance.new("BoolValue")
                silence.Name = "silence_listen_warning"
                silence.Parent = humanoid
            end
            local animController = character:FindFirstChildOfClass("AnimationController")
            if animController and not animController:FindFirstChild("silence_listen_warning") then
                local silence = Instance.new("BoolValue")
                silence.Name = "silence_listen_warning"
                silence.Parent = animController
            end
        end
    end
    silenceListenWarnings()
    LocalPlayer.CharacterAdded:Connect(silenceListenWarnings)

    -- Bypass Emotes (ใช้ SetAttribute แทนการกำหนด property โดยตรง)
    local function hookButton(button)
        if not button or button:GetAttribute("BypassHooked") then return end
        button:SetAttribute("BypassHooked", true)

        if button:FindFirstChild("UnlocksAtText") then
            button.UnlocksAtText.Visible = false
        end
        if button:FindFirstChild("EmoteName") then
            button.EmoteName.Visible = true
        end

        local successCoreUI, CoreUI = pcall(require, ReplicatedStorage.Modules.Core.UI)
        if successCoreUI and CoreUI and CoreUI.on_click then
            pcall(CoreUI.on_click, button, function() end)
        end
    end

    -- Bypass Hotbar
    local function lockTool(tool)
        if tool and tool:IsA("Tool") then
            pcall(function() tool:SetAttribute("Locked", true) end)
        end
    end

    local function setupBackpack(backpack)
        if not backpack then return end
        for _, tool in ipairs(backpack:GetChildren()) do
            lockTool(tool)
        end
        backpack.ChildAdded:Connect(lockTool)
    end

    task.spawn(function()
        local backpack = LocalPlayer:FindFirstChildOfClass("Backpack")
        if backpack then
            setupBackpack(backpack)
        else
            LocalPlayer.ChildAdded:Connect(function(child)
                if child:IsA("Backpack") then
                    setupBackpack(child)
                end
            end)
        end
    end)

    -- Bypass Emotes UI
    task.spawn(function()
        local ok1, EmotesList = pcall(require, ReplicatedStorage.Modules.Game.Emotes.EmotesList)
        local ok2, CoreUI = pcall(require, ReplicatedStorage.Modules.Core.UI)
        if ok1 and ok2 and CoreUI and CoreUI.get then
            for _, emote in pairs(EmotesList) do
                local button = CoreUI.get("EmoteTemplate").Parent:FindFirstChild(emote.name)
                if button and not button:GetAttribute("BypassHooked") then
                    hookButton(button)
                end
            end
        end
    end)

    -- Bypass Tween
    local ok, Util = pcall(require, ReplicatedStorage.Modules.Core.Util)
    if ok and Util and not Util._bypassTween then
        Util._bypassTween = true
        local _old_tween = Util.tween
        Util.tween = function(instance, tweenInfo, properties)
            if instance and instance:IsA("NumberValue") and properties and properties.Value ~= nil then
                instance.Value = properties.Value
                return { Cancel = function() end }
            end
            return _old_tween(instance, tweenInfo, properties)
        end
    end

    -- Bypass BuyPrompt
    task.spawn(function()
        local ok, BuyPromptUI = pcall(require, ReplicatedStorage.Modules.Game.UI.BuyPromptUI)
        if ok and BuyPromptUI and BuyPromptUI.get then
            local sellBtn = BuyPromptUI.get("SellPromptSellButton")
            if sellBtn then
                local hold = sellBtn:FindFirstChild("HoldStroke", true)
                if hold then
                    hold.Enabled = false
                    local uiGrad = hold:FindFirstChildOfClass("UIGradient")
                    if uiGrad then uiGrad.Enabled = false end
                end
                for _, v in pairs(sellBtn:GetDescendants()) do
                    if v:IsA("NumberValue") then
                        v.Value = 1
                    end
                end
            end
        end
    end)
end


        return tab:Section(name, true)
    end

    -- ฟังก์ชันเพิ่ม Toggle (รองรับ LoadFuncs)
    local function AddToggle(section, title, desc, settingName)
        return section:Toggle(title, desc, function(state)
            _G[settingName] = state
            if LoadFuncs[settingName] then
                task.spawn(function()
                    while _G[settingName] do
                        LoadFuncs[settingName](state)
                        task.wait(0.1)
                    end
                end)
            end
